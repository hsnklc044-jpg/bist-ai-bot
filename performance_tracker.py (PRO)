import json
import os
from datetime import datetime

HISTORY_FILE = "history.json"

def load_history():
    if not os.path.exists(HISTORY_FILE):
        return {
            "equity": 100000,
            "trades": [],
            "wins": 0,
            "losses": 0
        }
    with open(HISTORY_FILE, "r") as f:
        return json.load(f)

def save_history(data):
    with open(HISTORY_FILE, "w") as f:
        json.dump(data, f, indent=4)

def record_trade(symbol, entry, exit_price, result):
    data = load_history()

    trade = {
        "symbol": symbol,
        "entry": entry,
        "exit": exit_price,
        "result": result,
        "date": str(datetime.now())
    }

    data["trades"].append(trade)

    pnl = exit_price - entry
    data["equity"] += pnl

    if pnl > 0:
        data["wins"] += 1
    else:
        data["losses"] += 1

    save_history(data)

def get_stats():
    data = load_history()
    total = data["wins"] + data["losses"]
    winrate = (data["wins"] / total * 100) if total > 0 else 0

    return {
        "equity": data["equity"],
        "wins": data["wins"],
        "losses": data["losses"],
        "winrate": round(winrate, 2),
        "total_trades": total
    }
